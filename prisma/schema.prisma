generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
}

enum UserRole {
  ADMIN
  MASTER_ADMIN
  VIEWER
  OPERATOR_ADMIN
  FINOPS_TECHNICIAN
  CLIENT_APPROVER
  CLIENT_VIEWER
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum CloudProvider {
  AWS
  OCI
  AZURE
  GCP
  CUSTOM
}

enum CloudAccountStatus {
  ACTIVE
  DISABLED
}

enum IngestionStatus {
  RUNNING
  SUCCESS
  FAILED
}

enum TenantAccessRole {
  TECHNICIAN
  LEAD_TECHNICIAN
  OPERATOR_ADMIN
}

enum ProviderCapability {
  FOCUS_EXPORT
  CROSS_ACCOUNT_DELIVERY
  INVENTORY
  TECHNICAL_METRICS
  OPTIONAL_AGENTS
}

enum CredentialPurpose {
  TEMPORARY_ADMIN
  OPERATIONAL
  BILLING_EXPORT_READ
  INVENTORY_READ
  METRICS_READ
  STORAGE_READ
  STORAGE_WRITE
}

enum CredentialStatus {
  ACTIVE
  DISABLED
  REVOKED
  EXPIRED
}

enum IngestionJobStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  CANCELLED
}

enum IngestionSourceType {
  BILLING_EXPORT
  INVENTORY
  TECHNICAL_METRIC
  AGENT_METRIC
}

enum DataQualityStatus {
  PASSED
  WARNING
  FAILED
}

enum CloudResourceStatus {
  ACTIVE
  STOPPED
  TERMINATED
  UNKNOWN
}

enum AgentInstallationStatus {
  NOT_INSTALLED
  INSTALLED
  DISABLED
  UNKNOWN
}

enum RecommendationStatus {
  PENDING
  APPROVED
  REJECTED
  MANUAL_COMPLETED
}

enum RecommendationSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RecommendationDecisionType {
  APPROVED
  REJECTED
  MARKED_DONE
}

enum RecommendationFeedbackReason {
  APPROVED_HIGH_CONFIDENCE
  APPROVED_LOW_RISK_QUICK_WIN
  REJECTED_INSUFFICIENT_EVIDENCE
  REJECTED_SAVINGS_UNREALISTIC
  REJECTED_OPERATIONAL_RISK
  REJECTED_BUSINESS_EXCEPTION
  REJECTED_ALREADY_HANDLED
  REJECTED_WRONG_SCOPE
  REJECTED_NOT_ACTIONABLE
}

enum AiAuditVerdict {
  APPROVED
  REJECTED
  NEEDS_REVISION
}

enum AgentLearningStatus {
  PENDING
  APPROVED
  REJECTED
  SKIPPED
  ERROR
}

enum AgentMemoryScope {
  LOCAL
  GLOBAL
}

enum AgentMemoryType {
  RULE
  LESSON
  APPROVAL_PATTERN
  REJECTION_PATTERN
  DECISION_PATTERN
}

enum CostAnomalySeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum CostAnomalyStatus {
  OPEN
  LINKED_TO_RECOMMENDATION
  RESOLVED
}

enum InAppNotificationType {
  SAVINGS_REMINDER
  BUDGET_ALERT
}

enum BudgetScope {
  TENANT
  CLOUD_ACCOUNT
  SERVICE
}

enum BudgetStatus {
  ACTIVE
  ARCHIVED
}

enum BudgetAlertLevel {
  WARNING
  CRITICAL
  EXCEEDED
}

enum InAppNotificationStatus {
  UNREAD
  READ
  DISMISSED
}

enum AgentInstructionProfileStatus {
  DRAFT
  ACTIVE
  ARCHIVED
  REJECTED
}

enum TenantAgentRuleStatus {
  ACTIVE
  DISABLED
}

enum AiContextOperation {
  CHAT
  RECOMMENDATION
  EXECUTION_PLAN
  AUDIT
  LEARNING
}

enum ContextBuildRunStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

enum TelegramChatLinkStatus {
  ACTIVE
  DISABLED
}

enum TelegramInteractionStatus {
  PROCESSED
  IGNORED
  ERROR
}

enum OutboundMessageChannel {
  TELEGRAM
  EMAIL
}

enum OutboundMessageType {
  TEST
  SAVINGS_REMINDER
  AI_CHAT_RESPONSE
  RECOMMENDATION_SUMMARY
  EXECUTION_PLAN_READY
  BUDGET_ALERT
}

enum OutboundMessageStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

enum ManualExecutionStatus {
  PLANNED
  EXECUTED
  PARTIAL
  CANCELLED
}

model Tenant {
  id                       String                    @id @default(cuid())
  operatorOrganizationId   String?                   @map("operator_organization_id")
  name                     String
  slug                     String                    @unique
  status                   TenantStatus              @default(ACTIVE)
  createdAt                DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime                  @updatedAt @map("updated_at") @db.Timestamptz(6)
  users                    User[]
  cloudAccounts            CloudAccount[]
  ingestionRuns            IngestionRun[]
  costMetrics              CostMetric[]
  recommendations          Recommendation[]
  auditEvents              AuditEvent[]
  operatorOrganization     OperatorOrganization?     @relation(fields: [operatorOrganizationId], references: [id], onDelete: SetNull)
  accessAssignments        TenantAccessAssignment[]
  cloudConnections         CloudConnection[]
  operatorStorageLocations OperatorStorageLocation[]
  ingestionJobs            IngestionJob[]
  ingestionObjects         IngestionObject[]
  ingestionWatermarks      IngestionWatermark[]
  focusCostLineItems       FocusCostLineItem[]
  cloudResources           CloudResource[]
  resourceMetricSamples    ResourceMetricSample[]
  agentInstallations       AgentInstallation[]
  dataQualityChecks        DataQualityCheck[]
  agentLearningEvents      AgentLearningEvent[]
  agentMemories            AgentMemory[]
  tenantAgentRules         TenantAgentRule[]
  agentInstructionAuditEvents AgentInstructionAuditEvent[]
  contextSummaryCaches     ContextSummaryCache[]
  aiContextTraces          AiContextTrace[]
  contextBuildRuns         ContextBuildRun[]
  telegramChatLinks        TelegramChatLink[]
  telegramInteractionLogs  TelegramInteractionLog[]
  costAnomalies            CostAnomaly[]
  costForecasts            CostForecast[]
  manualExecutions         RecommendationManualExecution[]
  inAppNotifications       InAppNotification[]
  outboundMessageDeliveries OutboundMessageDelivery[]
  budgets                  Budget[]
  budgetAlerts             BudgetAlert[]

  @@index([operatorOrganizationId, status])
  @@map("tenants")
}

model User {
  id                         String                        @id @default(cuid())
  operatorOrganizationId     String?                       @map("operator_organization_id")
  tenantId                   String                        @map("tenant_id")
  email                      String                        @unique
  name                       String
  passwordHash               String                        @map("password_hash")
  role                       UserRole                      @default(VIEWER)
  status                     UserStatus                    @default(ACTIVE)
  lastLoginAt                DateTime?                     @map("last_login_at") @db.Timestamptz(6)
  createdAt                  DateTime                      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                  DateTime                      @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenant                     Tenant                        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessions                   AuthSession[]
  decisions                  RecommendationDecision[]
  executionPlans             RecommendationExecutionPlan[]
  manualExecutions           RecommendationManualExecution[]
  auditEvents                AuditEvent[]
  operatorOrganization       OperatorOrganization?         @relation(fields: [operatorOrganizationId], references: [id], onDelete: SetNull)
  tenantAccessAssignments    TenantAccessAssignment[]
  generatedIngestionJobs     IngestionJob[]                @relation("IngestionJobRequestedBy")
  generatedDataQualityChecks DataQualityCheck[]            @relation("DataQualityCheckCreatedBy")
  agentLearningEvents        AgentLearningEvent[]
  inAppNotifications         InAppNotification[]
  createdAgentInstructionProfiles   AgentInstructionProfile[]    @relation("AgentInstructionProfileCreatedBy")
  activatedAgentInstructionProfiles AgentInstructionProfile[]    @relation("AgentInstructionProfileActivatedBy")
  createdTenantAgentRules           TenantAgentRule[]            @relation("TenantAgentRuleCreatedBy")
  agentInstructionAuditEvents       AgentInstructionAuditEvent[] @relation("AgentInstructionAuditActor")
  aiContextTraces                   AiContextTrace[]
  createdContextBuildRuns           ContextBuildRun[]            @relation("ContextBuildRunCreatedBy")
  telegramChatLinks                 TelegramChatLink[]           @relation("TelegramChatLinkUser")
  linkedTelegramChatLinks           TelegramChatLink[]           @relation("TelegramChatLinkLinkedBy")
  telegramInteractionLogs           TelegramInteractionLog[]
  outboundMessageDeliveries         OutboundMessageDelivery[]
  createdBudgets                    Budget[]                 @relation("BudgetCreatedBy")

  @@index([operatorOrganizationId, role])
  @@index([tenantId, role])
  @@map("users")
}

model OperatorOrganization {
  id        String       @id @default(cuid())
  name      String
  slug      String       @unique
  status    TenantStatus @default(ACTIVE)
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenants   Tenant[]
  users     User[]

  @@map("operator_organizations")
}

model TenantAccessAssignment {
  id         String           @id @default(cuid())
  tenantId   String           @map("tenant_id")
  userId     String           @map("user_id")
  role       TenantAccessRole @default(TECHNICIAN)
  createdAt  DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  disabledAt DateTime?        @map("disabled_at") @db.Timestamptz(6)
  tenant     Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([userId, disabledAt])
  @@index([tenantId, role])
  @@map("tenant_access_assignments")
}

model ProviderCatalog {
  code                String               @id
  displayName         String               @map("display_name")
  provider            CloudProvider
  capabilities        ProviderCapability[]
  defaultFocusVersion String?              @map("default_focus_version")
  documentationUrl    String?              @map("documentation_url")
  enabled             Boolean              @default(true)
  createdAt           DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  cloudConnections    CloudConnection[]

  @@index([provider, enabled])
  @@map("provider_catalog")
}

model CloudConnection {
  id                    String                      @id @default(cuid())
  tenantId              String                      @map("tenant_id")
  providerCode          String                      @map("provider_code")
  rootExternalId        String                      @map("root_external_id")
  name                  String
  status                CloudAccountStatus          @default(ACTIVE)
  defaultRegion         String?                     @map("default_region")
  metadata              Json?
  lastValidatedAt       DateTime?                   @map("last_validated_at") @db.Timestamptz(6)
  createdAt             DateTime                    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime                    @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenant                Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  providerCatalog       ProviderCatalog             @relation(fields: [providerCode], references: [code], onDelete: Restrict)
  credentials           CloudConnectionCredential[]
  exportConfigs         CloudExportConfig[]
  ingestionJobs         IngestionJob[]
  ingestionRuns         IngestionRun[]
  ingestionObjects      IngestionObject[]
  ingestionWatermarks   IngestionWatermark[]
  focusCostLineItems    FocusCostLineItem[]
  cloudResources        CloudResource[]
  resourceMetricSamples ResourceMetricSample[]
  agentInstallations    AgentInstallation[]
  dataQualityChecks     DataQualityCheck[]

  @@unique([tenantId, providerCode, rootExternalId])
  @@index([tenantId, status])
  @@index([providerCode, status])
  @@map("cloud_connections")
}

model CloudConnectionCredential {
  id                   String            @id @default(cuid())
  cloudConnectionId    String            @map("cloud_connection_id")
  purpose              CredentialPurpose
  status               CredentialStatus  @default(ACTIVE)
  label                String
  encryptedPayload     String            @map("encrypted_payload") @db.Text
  encryptionIv         String            @map("encryption_iv")
  encryptionAuthTag    String            @map("encryption_auth_tag")
  encryptionAlgorithm  String            @default("aes-256-gcm") @map("encryption_algorithm")
  encryptionKeyVersion String            @default("v1") @map("encryption_key_version")
  externalPrincipalId  String?           @map("external_principal_id")
  expiresAt            DateTime?         @map("expires_at") @db.Timestamptz(6)
  createdAt            DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  disabledAt           DateTime?         @map("disabled_at") @db.Timestamptz(6)
  revokedAt            DateTime?         @map("revoked_at") @db.Timestamptz(6)
  cloudConnection      CloudConnection   @relation(fields: [cloudConnectionId], references: [id], onDelete: Cascade)

  @@index([cloudConnectionId, purpose, status])
  @@index([expiresAt])
  @@map("cloud_connection_credentials")
}

model OperatorStorageLocation {
  id            String              @id @default(cuid())
  tenantId      String              @map("tenant_id")
  provider      String              @default("s3-compatible")
  bucketName    String              @map("bucket_name")
  basePrefix    String              @map("base_prefix")
  kmsKeyRef     String?             @map("kms_key_ref")
  retentionDays Int                 @default(730) @map("retention_days")
  createdAt     DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  exportConfigs CloudExportConfig[]

  @@unique([tenantId, bucketName])
  @@map("operator_storage_locations")
}

model CloudExportConfig {
  id                String                   @id @default(cuid())
  cloudConnectionId String                   @map("cloud_connection_id")
  storageLocationId String?                  @map("storage_location_id")
  sourceType        IngestionSourceType      @default(BILLING_EXPORT) @map("source_type")
  focusVersion      String?                  @map("focus_version")
  externalExportId  String?                  @map("external_export_id")
  exportPath        String?                  @map("export_path")
  schedule          String                   @default("daily")
  status            CloudAccountStatus       @default(ACTIVE)
  lastDeliveredAt   DateTime?                @map("last_delivered_at") @db.Timestamptz(6)
  createdAt         DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)
  cloudConnection   CloudConnection          @relation(fields: [cloudConnectionId], references: [id], onDelete: Cascade)
  storageLocation   OperatorStorageLocation? @relation(fields: [storageLocationId], references: [id], onDelete: SetNull)
  ingestionObjects  IngestionObject[]

  @@index([cloudConnectionId, sourceType, status])
  @@map("cloud_export_configs")
}

model AuthSession {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  jwtId     String    @unique @map("jwt_id")
  issuedAt  DateTime  @default(now()) @map("issued_at") @db.Timestamptz(6)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(6)
  ipAddress String?   @map("ip_address")
  userAgent String?   @map("user_agent")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@map("auth_sessions")
}

model CloudAccount {
  id                String             @id @default(cuid())
  tenantId          String             @map("tenant_id")
  provider          CloudProvider
  externalAccountId String             @map("external_account_id")
  name              String
  defaultRegion     String?            @map("default_region")
  status            CloudAccountStatus @default(ACTIVE)
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ingestionRuns     IngestionRun[]
  costMetrics       CostMetric[]
  recommendations   Recommendation[]
  costAnomalies     CostAnomaly[]
  costForecasts     CostForecast[]
  budgets           Budget[]

  @@unique([tenantId, provider, externalAccountId])
  @@index([tenantId, status])
  @@map("cloud_accounts")
}

model IngestionRun {
  id                String           @id @default(cuid())
  tenantId          String           @map("tenant_id")
  cloudAccountId    String           @map("cloud_account_id")
  cloudConnectionId String?          @map("cloud_connection_id")
  provider          CloudProvider
  targetDate        DateTime         @map("target_date") @db.Date
  startedAt         DateTime         @default(now()) @map("started_at") @db.Timestamptz(6)
  completedAt       DateTime?        @map("completed_at") @db.Timestamptz(6)
  status            IngestionStatus  @default(RUNNING)
  trigger           String           @default("manual")
  metricsCount      Int              @default(0) @map("metrics_count")
  errorMessage      String?          @map("error_message") @db.Text
  tenant            Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cloudAccount      CloudAccount     @relation(fields: [cloudAccountId], references: [id], onDelete: Cascade)
  cloudConnection   CloudConnection? @relation(fields: [cloudConnectionId], references: [id], onDelete: SetNull)
  costMetrics       CostMetric[]

  @@index([tenantId, targetDate])
  @@index([cloudAccountId, startedAt])
  @@index([cloudConnectionId, startedAt])
  @@map("ingestion_runs")
}

model IngestionJob {
  id                String              @id @default(cuid())
  tenantId          String              @map("tenant_id")
  cloudConnectionId String              @map("cloud_connection_id")
  sourceType        IngestionSourceType @map("source_type")
  status            IngestionJobStatus  @default(PENDING)
  requestedByUserId String?             @map("requested_by_user_id")
  targetStart       DateTime            @map("target_start") @db.Timestamptz(6)
  targetEnd         DateTime            @map("target_end") @db.Timestamptz(6)
  attempts          Int                 @default(0)
  maxAttempts       Int                 @default(3) @map("max_attempts")
  startedAt         DateTime?           @map("started_at") @db.Timestamptz(6)
  completedAt       DateTime?           @map("completed_at") @db.Timestamptz(6)
  lockedAt          DateTime?           @map("locked_at") @db.Timestamptz(6)
  lockedBy          String?             @map("locked_by")
  errorMessage      String?             @map("error_message") @db.Text
  resultSummary     Json?               @map("result_summary")
  createdAt         DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenant            Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cloudConnection   CloudConnection     @relation(fields: [cloudConnectionId], references: [id], onDelete: Cascade)
  requestedBy       User?               @relation("IngestionJobRequestedBy", fields: [requestedByUserId], references: [id], onDelete: SetNull)

  @@index([status, sourceType, createdAt])
  @@index([tenantId, cloudConnectionId, sourceType])
  @@map("ingestion_jobs")
}

model IngestionObject {
  id                String              @id @default(cuid())
  tenantId          String              @map("tenant_id")
  cloudConnectionId String              @map("cloud_connection_id")
  exportConfigId    String?             @map("export_config_id")
  sourceType        IngestionSourceType @map("source_type")
  objectUri         String              @map("object_uri")
  objectEtag        String?             @map("object_etag")
  objectVersion     String?             @map("object_version")
  contentHash       String?             @map("content_hash")
  status            IngestionJobStatus  @default(PENDING)
  rowsProcessed     Int                 @default(0) @map("rows_processed")
  firstSeenAt       DateTime            @default(now()) @map("first_seen_at") @db.Timestamptz(6)
  processedAt       DateTime?           @map("processed_at") @db.Timestamptz(6)
  errorMessage      String?             @map("error_message") @db.Text
  tenant            Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cloudConnection   CloudConnection     @relation(fields: [cloudConnectionId], references: [id], onDelete: Cascade)
  exportConfig      CloudExportConfig?  @relation(fields: [exportConfigId], references: [id], onDelete: SetNull)

  @@unique([cloudConnectionId, objectUri, objectEtag])
  @@index([tenantId, sourceType, status])
  @@map("ingestion_objects")
}

model IngestionWatermark {
  id                  String              @id @default(cuid())
  tenantId            String              @map("tenant_id")
  cloudConnectionId   String              @map("cloud_connection_id")
  sourceType          IngestionSourceType @map("source_type")
  watermarkStart      DateTime?           @map("watermark_start") @db.Timestamptz(6)
  watermarkEnd        DateTime?           @map("watermark_end") @db.Timestamptz(6)
  lastSuccessfulRunAt DateTime?           @map("last_successful_run_at") @db.Timestamptz(6)
  freshnessDeadlineAt DateTime?           @map("freshness_deadline_at") @db.Timestamptz(6)
  createdAt           DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenant              Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cloudConnection     CloudConnection     @relation(fields: [cloudConnectionId], references: [id], onDelete: Cascade)

  @@unique([cloudConnectionId, sourceType])
  @@index([tenantId, sourceType])
  @@map("ingestion_watermarks")
}

model FocusCostLineItem {
  id                 String          @id @default(cuid())
  tenantId           String          @map("tenant_id")
  cloudConnectionId  String          @map("cloud_connection_id")
  provider           CloudProvider
  focusVersion       String          @map("focus_version")
  chargePeriodStart  DateTime        @map("charge_period_start") @db.Timestamptz(6)
  chargePeriodEnd    DateTime        @map("charge_period_end") @db.Timestamptz(6)
  billingPeriodStart DateTime?       @map("billing_period_start") @db.Timestamptz(6)
  billingPeriodEnd   DateTime?       @map("billing_period_end") @db.Timestamptz(6)
  billingAccountId   String?         @map("billing_account_id")
  subAccountId       String?         @map("sub_account_id")
  serviceName        String          @map("service_name")
  resourceId         String          @default("") @map("resource_id")
  regionId           String?         @map("region_id")
  chargeCategory     String          @default("Usage") @map("charge_category")
  billedCost         Decimal         @map("billed_cost") @db.Decimal(18, 6)
  effectiveCost      Decimal?        @map("effective_cost") @db.Decimal(18, 6)
  listCost           Decimal?        @map("list_cost") @db.Decimal(18, 6)
  contractedCost     Decimal?        @map("contracted_cost") @db.Decimal(18, 6)
  billingCurrency    String          @map("billing_currency") @db.VarChar(3)
  consumedQuantity   Decimal?        @map("consumed_quantity") @db.Decimal(24, 9)
  consumedUnit       String?         @map("consumed_unit")
  tags               Json?
  rawRow             Json            @map("raw_row")
  lineItemHash       String          @map("line_item_hash")
  createdAt          DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  tenant             Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cloudConnection    CloudConnection @relation(fields: [cloudConnectionId], references: [id], onDelete: Cascade)

  @@unique([cloudConnectionId, chargePeriodStart, lineItemHash])
  @@index([tenantId, provider, chargePeriodStart])
  @@index([tenantId, serviceName, chargePeriodStart])
  @@index([resourceId])
  @@map("focus_cost_line_items")
}

model CloudResource {
  id                 String                 @id @default(cuid())
  tenantId           String                 @map("tenant_id")
  cloudConnectionId  String                 @map("cloud_connection_id")
  provider           CloudProvider
  externalResourceId String                 @map("external_resource_id")
  name               String?
  resourceType       String                 @map("resource_type")
  serviceName        String                 @map("service_name")
  regionId           String?                @map("region_id")
  status             CloudResourceStatus    @default(UNKNOWN)
  tags               Json?
  rawResource        Json?                  @map("raw_resource")
  firstSeenAt        DateTime               @default(now()) @map("first_seen_at") @db.Timestamptz(6)
  lastSeenAt         DateTime               @default(now()) @map("last_seen_at") @db.Timestamptz(6)
  tenant             Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cloudConnection    CloudConnection        @relation(fields: [cloudConnectionId], references: [id], onDelete: Cascade)
  metricSamples      ResourceMetricSample[]
  agentInstallations AgentInstallation[]

  @@unique([cloudConnectionId, externalResourceId])
  @@index([tenantId, provider, resourceType])
  @@index([tenantId, status])
  @@map("cloud_resources")
}

model ResourceMetricSample {
  id                 String              @id @default(cuid())
  tenantId           String              @map("tenant_id")
  cloudConnectionId  String              @map("cloud_connection_id")

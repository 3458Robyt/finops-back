model TelegramChatLink {
  id               String                 @id @default(cuid())
  tenantId         String                 @map("tenant_id")
  userId           String                 @map("user_id")
  chatId           String                 @map("chat_id")
  telegramUserId   String?                @map("telegram_user_id")
  telegramUsername String?                @map("telegram_username")
  status           TelegramChatLinkStatus @default(ACTIVE)
  linkedByUserId   String                 @map("linked_by_user_id")
  disabledAt       DateTime?              @map("disabled_at") @db.Timestamptz(6)
  createdAt        DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)

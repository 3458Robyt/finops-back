  summary        String    @db.Text
  facts          Json?
  evidenceRefs   Json?     @map("evidence_refs")
  tokenEstimate  Int       @default(0) @map("token_estimate")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, artifactType, scopeKey, sourceHash])
  @@index([tenantId, artifactType, updatedAt])
  @@index([tenantId, provider, serviceName])
  @@index([tenantId, resourceId])
  @@map("context_summary_cache")
}

model AiContextTrace {
  id                    String             @id @default(cuid())
  tenantId              String             @map("tenant_id")
  userId                String?            @map("user_id")
  operation             AiContextOperation
  model                 String
  status                String
  profileVersion        Int?               @map("profile_version")
  promptTokenEstimate   Int                @default(0) @map("prompt_token_estimate")
  responseTokenEstimate Int?               @map("response_token_estimate")
  latencyMs             Int?               @map("latency_ms")
  artifactIds           Json?              @map("artifact_ids")
  memoryIds             Json?              @map("memory_ids")
  tenantRuleIds         Json?              @map("tenant_rule_ids")
  conflicts             Json?
  errorMessage          String?            @map("error_message") @db.Text
  createdAt             DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  expiresAt             DateTime           @map("expires_at") @db.Timestamptz(6)
  tenant                Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user                  User?              @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, operation, createdAt])
  @@index([tenantId, status, createdAt])
  @@index([expiresAt])
  @@map("ai_context_traces")
}


{
  "name": "finops-backend",
  "version": "1.0.0",
  "description": "FinOps Inteligente - Backend Core para optimización de costos multicloud (TAK Colombia)",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "prisma generate && tsc && node -e \"require('node:fs').cpSync('src/generated/prisma', 'dist/generated/prisma', { recursive: true })\"",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "prisma generate && tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:integration": "cross-env RUN_DB_INTEGRATION_TESTS=true vitest run src/testing/e2eFixtures.test.ts src/testing/**/*.integration.test.ts",
    "test:integration:docker": "docker compose -f docker-compose.test.yml up -d --wait && cross-env DATABASE_URL=postgresql://finops:finops@localhost:55432/finops_test prisma migrate deploy && cross-env TEST_DATABASE_URL=postgresql://finops:finops@localhost:55432/finops_test ALLOW_DESTRUCTIVE_TEST_DATABASE=true RUN_DB_INTEGRATION_TESTS=true vitest run src/testing/e2eFixtures.test.ts src/testing/**/*.integration.test.ts",
    "test:api:smoke": "tsx scripts/testing/api-smoke.ts",
    "test:ai:offline": "vitest run src/application/services/ai/evaluation",
    "test:ai:live": "tsx scripts/testing/ai-live-audit.ts",
    "test:perf:technical-metrics": "tsx scripts/testing/technical-metrics-perf.ts",
    "test:fixtures:create": "tsx scripts/testing/create-e2e-fixtures.ts",
    "test:fixtures:cleanup": "tsx scripts/testing/cleanup-e2e-fixtures.ts",
    "test:all": "npm run typecheck && npm run test:unit && npm run test:ai:offline && npm run build",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "import:oci-focus": "tsx scripts/import-oci-focus.ts",
    "aws:register-role": "tsx scripts/register-aws-role-credential.ts",
    "ingestion:configure-focus": "tsx scripts/configure-focus-source.ts",
    "ingestion:doctor": "tsx scripts/check-ingestion-readiness.ts",
    "ingestion:create-job": "tsx scripts/create-ingestion-job.ts",
    "ingestion:schedule": "tsx scripts/schedule-ingestion-jobs.ts",
    "ingestion:worker:once": "tsx scripts/run-ingestion-worker-once.ts",
    "ingestion:worker:preflight": "tsx scripts/run-ingestion-worker-once.ts --preflight",
    "ingestion:preview-focus": "tsx scripts/preview-focus-sources.ts",
    "oci:register-profile": "tsx scripts/register-oci-profile-credential.ts",
    "telegram:set-webhook": "tsx scripts/telegram-set-webhook.ts",
    "users:consolidate-admin-tenants": "tsx scripts/consolidate-admin-tenants.ts"
  },
  "keywords": [
    "finops",
    "cloud-cost",
    "multicloud",
    "aws",
    "oci",
    "timescaledb"
  ],
  "author": "TAK Colombia",
  "license": "UNLICENSED",
  "dependencies": {
    "@aws-sdk/client-cloudwatch": "^3.1062.0",
    "@aws-sdk/client-cost-explorer": "^3.750.0",
    "@aws-sdk/client-ec2": "^3.1073.0",
    "@aws-sdk/client-s3": "^3.1062.0",
    "@aws-sdk/client-sts": "^3.1062.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "argon2": "^0.44.0",
    "cors": "^2.8.5",
    "csv-parse": "^6.2.1",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^9.0.1",
    "oci-sdk": "^2.100.0",
    "openai": "^6.35.0",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.13.10",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "cross-env": "^10.1.0",
    "prisma": "^7.8.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^4.1.5"
  }
}

{
  "name": "finops-backend",
  "version": "1.0.0",
  "description": "FinOps Inteligente - Backend Core para optimización de costos multicloud (TAK Colombia)",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "prisma generate && tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "prisma generate && tsc --noEmit",
    "test": "vitest run",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "import:oci-focus": "tsx scripts/import-oci-focus.ts",
    "telegram:set-webhook": "tsx scripts/telegram-set-webhook.ts"
  },
  "keywords": [
    "finops",
    "cloud-cost",
    "multicloud",
    "aws",
    "oci",
    "timescaledb"
  ],
  "author": "TAK Colombia",
  "license": "UNLICENSED",
  "dependencies": {
    "@aws-sdk/client-cost-explorer": "^3.750.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "argon2": "^0.44.0",
    "cors": "^2.8.5",
    "csv-parse": "^6.2.1",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "oci-sdk": "^2.100.0",
    "openai": "^6.35.0",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.13.10",
    "@types/pg": "^8.20.0",
    "prisma": "^7.8.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^4.1.5"
  }
}
